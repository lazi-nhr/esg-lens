# .env.example — placeholder values only. Do NOT commit secrets here.

# Server
BACKEND_PORT=8500
BACKEND_HOST=0.0.0.0
BACKEND_URL=localhost

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nuvolos
DB_USER=nuvolos
DB_PASSWORD=

# Embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=384
MIN_CHUNK_TOKENS=100
MAX_CHUNK_TOKENS=800

# LLM / Inference
LLM_PROVIDER=huggingface
HF_MODEL=Qwen/Qwen2.5-7B
HF_API_KEY=
HF_HOME=/files/.hf_cache

# App behavior
BACKEND_STARTUP_TIMEOUT=180
DEFAULT_TOP_K=10
MAX_TOP_K=100

# Notes:
# - Copy this file to .env and fill in secrets before running locally.
# - Keep .env out of version control; only .env.example should be committed.
